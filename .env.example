# Copie para .env.local (nĂŁo commitar). Use apenas URL + chave anon no frontend.
# Nunca coloque service_role ou segredos no Vite (eles ficam expostos no bundle).

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
